# =================================================================
# Local AI Bank Statement Converter - Backend Configuration Example
# =================================================================

# FastAPI Application Settings
SECRET_KEY=super-secret-key-for-local-ai-bank-converter-1234567890
API_V1_STR=/api
PROJECT_NAME="Local AI Bank Statement Converter"

# Database Configuration (SQLite default)
DATABASE_URL=sqlite:///./bank_statement_converter.db

# Storage Directories
UPLOAD_DIR=./uploads
TEMP_DIR=./temp
MAX_FILE_SIZE_MB=150

# Security Encryption Key for API credentials (e.g. Groq, OpenAI keys)
# Must be a 32-byte url-safe base64-encoded key (Fernet).
# Leave blank to let the app auto-generate one in backend/.enc_key on first run.
# ENCRYPTION_KEY=

# OCR Engines Settings
# Path to your local tesseract executable on Windows if it is not in the system PATH.
# Example: TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# TESSERACT_CMD=

# Ollama LLM Coordinator settings
OLLAMA_BASE_URL=http://localhost:11434
